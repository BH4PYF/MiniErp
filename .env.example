# MiniErp 环境变量配置
# 复制为 .env 并修改实际值
# docker compose 自动加载此文件

# 安全密钥（必改！）
# 生成: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=请替换为随机生成的密钥

# 调试模式（生产环境必须 False）
DEBUG=True

# 允许的主机（逗号分隔，生产环境指定实际域名）
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF 可信源（逗号分隔，生产环境指定实际域名）
CSRF_TRUSTED_ORIGINS=https://your-domain.com,http://your-domain.com

# 数据库配置
DB_NAME=material_system
DB_USER=postgres
DB_PASSWORD=请设置数据库密码
DB_HOST=127.0.0.1
DB_PORT=5432

# 时区和语言
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# Sentry 错误追踪（可选）
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
